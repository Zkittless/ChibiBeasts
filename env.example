# ChibiBeasts Discord Bot — Environment Variables
# Copy this file to .env for local development.
# On Railway, set these under your service's "Variables" tab instead —
# Railway injects them automatically, you do not need a .env file in production.

# Required — your bot's token from https://discord.com/developers/applications
# (Application -> Bot -> Reset Token). Keep this secret; never commit it.
DISCORD_TOKEN=your_bot_token_here

# Required for instant slash-command sync during development/single-server use.
# Right-click your Discord server icon -> Copy Server ID (enable Developer Mode
# under Discord Settings -> Advanced first). Commands registered to a single
# guild ID appear instantly; without this set correctly, commands may not sync.
# NOTE: if you plan to run ChibiBeasts in MORE THAN ONE server, guild-scoped
# sync only registers commands in this one server — see README.md for how to
# switch to global sync instead.
GUILD_ID=your_server_id_here

# Optional — Role ID for /dev commands (give items, reset accounts, etc).
# Right-click the role in Server Settings -> Roles, Copy Role ID.
# If not set, all /dev commands are disabled.
DEV_ROLE_ID=your_dev_role_id_here
